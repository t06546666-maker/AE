# ─── Resend (Email) ──────────────────────────────────────────────
# Sign up at: https://resend.com  (free: 3,000 emails/month)
# Create API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Must be a verified domain/email in your Resend account
# Format:  Name <email@yourdomain.com>
RESEND_FROM_EMAIL=rewards@yourdomain.com

# ─── WhatsApp Business — Meta Cloud API ─────────────────────────
# 1. Go to https://developers.facebook.com  → My Apps → Create App → Business
# 2. Add "WhatsApp" product to your app
# 3. Under WhatsApp → Getting Started, copy the temporary or permanent token
WA_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 4. Copy the Phone Number ID (NOT the phone number itself)
WA_PHONE_ID=1234567890123456
WA_API_VERSION=v23.0
WA_APP_SECRET=your_meta_app_secret
WA_VERIFY_TOKEN=create_a_random_webhook_verify_token
WA_REGISTRATION_TEMPLATE=customer_welcome_qr
WA_REWARD_TEMPLATE=reward_receipt
WA_TEMPLATE_LANGUAGE=en
# customer_welcome_qr body: name, merchant, customer ID, percentage, points earned, total points
# reward_receipt body: name, merchant, order number, amount, percentage, points earned, total points

# ─── Server ──────────────────────────────────────────────────────
PORT=3000
CORS_ORIGINS=

# Supabase > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
# Backend only. Never expose this key in public/index.html.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
